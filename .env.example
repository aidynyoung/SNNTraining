# SNNTraining environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ── Zotero paper index (hdc/zotero_papers.py) ─────────────────────────────────
# Get your API key at: https://www.zotero.org/settings/keys
ZOTERO_API_KEY=your_api_key_here

# Numeric library ID shown when you create the key (e.g. 20360971)
ZOTERO_LIBRARY_ID=your_library_id_here

# "user" for personal library, "group" for a group library
ZOTERO_LIBRARY_TYPE=user

# Optional: restrict to a specific Zotero collection key (e.g. JTV8PX3T)
# Leave blank to index your entire library.
ZOTERO_COLLECTION_KEY=
